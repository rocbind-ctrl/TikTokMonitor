{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TikTokMonitor",
  "version": "0.2.17",
  "identifier": "com.tiktokmonitor.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "TikTokMonitor",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 680,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": "all",
    "category": "Business",
    "shortDescription": "TikTok account monitoring desktop client",
    "longDescription": "A cross-platform desktop client for connecting to a TikTokMonitor server."
  }
}
